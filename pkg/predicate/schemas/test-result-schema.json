{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "_type": {
      "type": "string",
      "const": "https://in-toto.io/Statement/v1"
    },
    "subject": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "digest": {
            "type": "object",
            "properties": {
              "sha256": {
                "type": "string"
              }
            },
            "required": ["sha256"]
          }
        },
        "required": ["name", "digest"]
      }
    },
    "predicateType": {
      "type": "string",
      "const": "https://in-toto.io/attestation/test-result/v0.1"
    },
    "predicate": {
      "type": "object",
      "properties": {
        "result": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "passedTests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnedTests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failedTests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["result", "passedTests", "warnedTests", "failedTests"]
    }
  },
  "required": ["_type", "subject", "predicateType", "predicate"]
}
