{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "_type": {
      "type": "string",
      "const": "https://in-toto.io/Statement/v1"
    },
    "subject": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "digest": {
            "type": "object",
            "properties": {
              "sha256": {
                "type": "string"
              }
            },
            "required": ["sha256"]
          }
        },
        "required": ["name", "digest"]
      }
    },
    "predicateType": {
      "type": "string",
      "const": "https://autogov.dev/attestation/code-scan/v0.1"
    },
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "maxLength": 256
              },
              "version": {
                "type": "string",
                "maxLength": 256
              },
              "informationUri": {
                "type": "string",
                "maxLength": 256
              }
            },
            "required": ["name"]
          }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "byLevel": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "error": { "type": "integer", "minimum": 0 },
                "warning": { "type": "integer", "minimum": 0 },
                "note": { "type": "integer", "minimum": 0 },
                "none": { "type": "integer", "minimum": 0 },
                "total": { "type": "integer", "minimum": 0 }
              },
              "required": ["error", "warning", "note", "none", "total"]
            },
            "bySecuritySeverity": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "critical": { "type": "integer", "minimum": 0 },
                "high": { "type": "integer", "minimum": 0 },
                "medium": { "type": "integer", "minimum": 0 },
                "low": { "type": "integer", "minimum": 0 },
                "none": { "type": "integer", "minimum": 0 },
                "total": { "type": "integer", "minimum": 0 }
              },
              "required": ["critical", "high", "medium", "low", "none", "total"]
            },
            "suppressed": { "type": "integer", "minimum": 0 },
            "new": { "type": "integer", "minimum": 0 }
          },
          "required": ["byLevel", "bySecuritySeverity", "suppressed"]
        },
        "configuration": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "uri": { "type": "string" },
              "digest": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "content": { "type": "string" },
              "downloadLocation": { "type": "string" },
              "mediaType": { "type": "string" },
              "annotations": { "type": "object" }
            },
            "anyOf": [
              { "required": ["uri"] },
              { "required": ["digest"] },
              { "required": ["content"] }
            ]
          }
        },
        "invocation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "executionSuccessful": { "type": "boolean" }
          },
          "required": ["executionSuccessful"]
        },
        "findingsIncluded": { "type": "boolean" },
        "truncated": { "type": "boolean" },
        "resultCount": { "type": "integer", "minimum": 0 },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ruleId": { "type": "string", "maxLength": 256 },
              "tool": { "type": "string", "maxLength": 256 },
              "level": {
                "type": "string",
                "enum": ["error", "warning", "note", "none"]
              },
              "kind": {
                "type": "string",
                "enum": ["fail"]
              },
              "securitySeverity": { "type": "string", "maxLength": 32 },
              "securitySeverityLevel": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low", "none"]
              },
              "message": { "type": "string", "maxLength": 512 },
              "location": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "uri": { "type": "string" },
                  "startLine": { "type": "integer", "minimum": 0 },
                  "endLine": { "type": "integer", "minimum": 0 }
                }
              },
              "baselineState": {
                "type": "string",
                "enum": ["new", "unchanged", "updated", "absent"]
              },
              "suppressed": { "type": "boolean" },
              "suppressionKind": { "type": "string", "maxLength": 64 },
              "partialFingerprints": {
                "type": "object",
                "maxProperties": 16,
                "propertyNames": { "maxLength": 128 },
                "additionalProperties": { "type": "string", "maxLength": 256 }
              }
            },
            "required": ["ruleId", "level", "kind", "suppressed"]
          }
        },
        "scanContext": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "commitSha": { "type": "string" },
            "ref": { "type": "string" },
            "url": { "type": "string" }
          }
        },
        "scanStartedOn": { "type": "string", "maxLength": 64 },
        "scanFinishedOn": { "type": "string", "maxLength": 64 }
      },
      "required": [
        "tools",
        "summary",
        "configuration",
        "invocation",
        "findingsIncluded",
        "truncated",
        "resultCount"
      ]
    }
  },
  "required": ["_type", "subject", "predicateType", "predicate"]
}
