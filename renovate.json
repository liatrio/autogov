{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "configMigration": true,
  "schedule": [
    "before 5am every weekday"
  ],
  "labels": [
    "renovate",
    "dependencies"
  ],
  "packageRules": [
    {
      "extends": [
        ":semanticPrefixFixDepsChoreOthers",
        "helpers:pinGitHubActionDigests"
      ],
      "matchDepTypes": [
        "action"
      ],
      "pinDigests": true,
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions"
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "prBodyNotes": [
        ":warning: MAJOR VERSION UPDATE :warning: - please manually update this package"
      ],
      "labels": [
        "dependency-major-update"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "/\\.github/workflows/.*\\.yaml$/"
      ],
      "matchStrings": [
        "(?:https://github\\.com/|)liatrio/liatrio-gh-autogov-workflows/\\.github/workflows/.*?\\.yaml@(?<currentDigest>[a-f0-9]+) # v(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "liatrio/liatrio-gh-autogov-workflows",
      "packageNameTemplate": "liatrio/liatrio-gh-autogov-workflows",
      "datasourceTemplate": "github-tags"
    }
  ]
}
